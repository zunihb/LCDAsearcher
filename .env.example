# Solo modelos con endpoint /v1/chat/completions funcionan con el cliente OpenAI de Python.
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_API_KEY=sk-tu-clave-opencode-go
# Opciones compatibles: deepseek-v4-flash | glm-5.1 | kimi-k2.6 | mimo-v2.5 | deepseek-v4-pro
LLM_MODEL=deepseek-v4-flash

