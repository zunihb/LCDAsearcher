# --- Backend del LLM ---
# openai = OpenAI-compatible API (OpenCode Go, OpenAI, etc.)
# gemini = Google Gemini API (más rápido para tool calling)
LLM_BACKEND=openai

# --- OpenCode Go (backend por defecto) ---
# Docs: https://opencode.ai/docs/go/
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_API_KEY=sk-tu-clave-opencode-go
LLM_MODEL=mimo-v2.5-pro

# --- Gemini (alternativa rápida, ~5x más veloz) ---
# Obtener clave en: https://aistudio.google.com/apikey
# GEMINI_API_KEY=tu-clave-gemini
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_THINKING=MINIMAL   # MINIMAL | LOW | HIGH

# --- OpenAI / otros (alternativa) ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
